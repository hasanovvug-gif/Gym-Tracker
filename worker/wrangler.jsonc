{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gymbar-ai-proxy",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "observability": { "enabled": true },
  "vars": {
    // Модель фиксирована на сервере — клиент её не выбирает.
    "GEMINI_MODEL": "gemini-3.5-flash",
    // Прямой Gemini. Для spend cap заменить на AI Gateway:
    // https://gateway.ai.cloudflare.com/v1/<account_id>/<gateway>/google-ai-studio/v1beta
    "GEMINI_BASE_URL": "https://generativelanguage.googleapis.com/v1beta"
  },
  // Секреты (wrangler secret put): GEMINI_API_KEY, APP_TOKEN
  "ratelimits": [
    {
      "name": "RL_IP",
      "namespace_id": "1001",
      "simple": { "limit": 10, "period": 60 }
    },
    {
      "name": "RL_GLOBAL",
      "namespace_id": "1002",
      "simple": { "limit": 40, "period": 60 }
    }
  ]
}
